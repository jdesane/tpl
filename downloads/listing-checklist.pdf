-menuMainItem: 1.4;\n  --letter-spacing-menuMainItem: 0em;\n  --font-weight-menuMainItem: 500;\n  --font-family-menuMainItem: var(--font-synonym), sans-serif;\n  --text-color-menuMainItem: #e5e4dd;\n}\n\n/* Base Layout - Prevents FOUC */\nhtml {\n  background: radial-gradient(at center bottom, rgb(30, 30, 30) 0%, rgb(8, 8, 8) 100%);\n  background-color: rgb(8, 8, 8);\n  scroll-behavior: smooth;\n  min-height: 100%;\n}\n\nbody {\n  margin: 0;\n  padding: 0;\n  background: radial-gradient(at center bottom, rgb(30, 30, 30) 0%, rgb(8, 8, 8) 100%);\n  background-color: rgb(8, 8, 8);\n  min-height: 100svh; /* Use svh (small viewport) to prevent layout shift when mobile address bar hides */\n  color: var(--color-text-secondary);\n  font-family: var(--font-synonym), 'Courier New', monospace;\n  -webkit-font-smoothing: antialiased;\n  -moz-osx-font-smoothing: grayscale;\n  /* Safari fix: use clip instead of hidden to prevent left offset issue */\n  overflow-x: clip;\n  width: 100%;\n  box-sizing: border-box;\n}\n\n/* Mobile: Disable fixed background to prevent scroll glitch with browser address bar */\n@media (max-width: 1024px), (hover: none) and (pointer: coarse) {\n  html,\n  body {\n    background-attachment: scroll;\n  }\n\n  /* Use locked viewport height on mobile to prevent layout shifts */\n  /* --vh-locked is set by ViewportHeightLock.tsx and only changes on true resize, not address bar */\n  /* --vh-locked-full is the full viewport height (--vh-locked * 100) for use in calc() */\n  body {\n    min-height: calc(var(--vh-locked, 1svh) * 100);\n  }\n\n  :root {\n    /* Full viewport height for mobile - used in calc() expressions */\n    /* This is set dynamically by ViewportHeightLock.tsx */\n    --vh-locked-full: calc(var(--vh-locked, 1svh) * 100);\n  }\n\n  /* Wolf pack hero background - disable fixed attachment on mobile */\n  .wolf-pack-bg {\n    background-attachment: scroll !important;\n  }\n}\n\n/* Critical Typography - H1 Hero Headlines */\nh1 {\n  font-family: var(--font-taskor), system-ui, sans-serif;\n  color: var(--color-text-primary);\n  font-weight: 400;\n  line-height: var(--line-height-h1, 1.2); /* Use Master Controller value, fallback 1.2 */\n  margin: 0;\n}\n\n/* H2 Section Titles */\nh2 {\n  font-family: var(--font-taskor), system-ui, sans-serif;\n  color: var(--color-text-primary);\n  font-weight: 400;\n  line-height: var(--line-height-h2, 1.2); /* Use Master Controller value, fallback 1.2 */\n  margin: 0;\n}\n\n/* Critical Layout Components */\nmain {\n  position: relative;\n  z-index: 1;\n  background: transparent;\n}\n\n/* Page content wrapper — no animation (removed) */\n\n/* Container for centering content */\n.container {\n  max-width: 1200px;\n  margin: 0 auto;\n  padding: 0 1rem;\n}\n\n/* Hero Section - Above the fold */\n.hero-section {\n  min-height: 100svh; /* Use svh (small viewport) to prevent layout shift when mobile address bar hides */\n  display: flex;\n  flex-direction: column;\n  justify-content: center;\n  align-items: center;\n  text-align: center;\n  position: relative;\n  z-index: 1;\n}\n\n/* Mobile: Use locked viewport height for hero sections */\n/* This prevents layout shifts when address bar hides/shows */\n@media (max-width: 1024px), (hover: none) and (pointer: coarse) {\n  .hero-section,\n  .min-h-\\[100dvh\\] {\n    min-height: calc(var(--vh-locked, 1svh) * 100) !important;\n  }\n\n  /* For elements using percentage of viewport (e.g., 80dvh) */\n  .h-\\[80dvh\\] {\n    height: calc(var(--vh-locked, 1svh) * 80) !important;\n  }\n}\n\n/* Critical Button Styles - Prevents flash */\nbutton {\n  font-family: var(--font-taskor), system-ui, sans-serif;\n  cursor: pointer;\n  border: none;\n  outline: none;\n}\n\n/* Link Styles - Only apply to paragraph links, not headings or buttons */\np a {\n  color: var(--color-green);\n  text-decoration: none;\n}\n\n/* Prevent Flash of Invisible Text (FOIT) */\n.font-taskor {\n  font-family: var(--font-taskor), system-ui, -apple-system, sans-serif;\n}\n\n.font-amulya {\n  font-family: var(--font-amulya), Georgia, serif;\n}\n\n.font-synonym {\n  font-family: var(--font-synonym), 'Courier New', monospace;\n}\n\n/* Respect reduced motion preference */\n@media (prefers-reduced-motion: reduce) {\n  .hero-entrance-animate {\n    animation: none !important;\n    opacity: 1 !important;\n    transform: none !important;\n  }\n}\n\n/* Hero Content Container Animation - Simple fade-in for H1, Tagline, Buttons */\n/* Applied to the container wrapping all hero text content */\n/* Single animation for entire group - minimal performance impact */\n/* NOTE: Uses opacity only (no transform) to avoid conflicting with Tailwind's -translate-x-1/2 */\n@keyframes heroContentFadeIn {\n  from {\n    opacity: 0;\n  }\n  to {\n    opacity: 1;\n  }\n}\n\n.hero-content-animate {\n  opacity: 0;\n  animation: heroContentFadeIn 0.5s ease-out 0.2s forwards;\n}\n\n/* Respect reduced motion preference */\n@media (prefers-reduced-motion: reduce) {\n  .hero-content-animate {\n    opacity: 1;\n    animation: none;\n  }\n}\n\n/* Profile Image - no animation, visible immediately */\n.profile-image {\n  opacity: 1;\n}\n\n/* Hero Effect Vignette - Ensure dark vignette renders immediately without pop-in */\n/* This matches the inline style in RevealMaskEffect and QuantumGridEffect */\n.hero-effect-layer {\n  opacity: 1;\n}\n\n/* Hero Vignette - simple bottom fade overlay for hero sections */\n/* No radial gradient / tunnel effect - just fades out at bottom */\n.hero-vignette {\n  position: absolute;\n  left: 0;\n  right: 0;\n  top: 0;\n  height: 100%;\n  background: transparent;\n  pointer-events: none;\n  /* Mask to fade out toward bottom - prevents hard line when scrolling */\n  mask-image: linear-gradient(to bottom, black 0%, black 60%, transparent 100%);\n  -webkit-mask-image: linear-gradient(to bottom, black 0%, black 60%, transparent 100%);\n}\n\n/* RevealMaskEffect initial state - prevents pop-in by providing immediate CSS */\n/* These styles render before React hydration, then React takes over */\n.reveal-mask-effect {\n  opacity: 1;\n}\n\n/* Golden glow initial state - 72% size (INITIAL_MASK_SIZE) */\n.reveal-mask-effect \u003e div:first-child {\n  background: radial-gradient(ellipse 72% 50.4% at 50% 50%,\n    rgba(255,215,0,0.2) 0%,\n    rgba(255,180,0,0.12) 35%,\n    rgba(255,150,0,0.06) 55%,\n    transparent 80%);\n}\n\n/* Master Controller Variables - Injected by useLiveCSS */\n/* Placeholder for dynamic CSS variables */\n#master-controller-vars {\n  /* CSS variables injected here by Master Controller */\n}\n\n/* Critical Responsive Breakpoints - Prevents FOUC on navigation */\n/* xlg breakpoint: 1440px (90rem) - Controls desktop nav vs mobile burger menu */\n@media (min-width: 90rem) {\n  .xlg\\:hidden {\n    display: none !important;\n  }\n\n  .xlg\\:flex {\n    display: flex !important;\n  }\n\n  .xlg\\:block {\n    display: block !important;\n  }\n\n  .xlg\\:left-auto {\n    left: auto !important;\n  }\n\n  .xlg\\:translate-x-0 {\n    --tw-translate-x: 0 !important;\n    transform: translate(var(--tw-translate-x, 0), var(--tw-translate-y, 0)) !important;\n  }\n\n  .xlg\\:right-8 {\n    right: 2rem !important;\n  }\n}\n\n/* Hamburger Menu - Prevent FOUC by providing base styles immediately */\n/* Position is static (flows inside header flex container) */\n.hamburger {\n  position: static;\n  width: 65px;\n  height: 65px;\n  cursor: pointer;\n  background-color: transparent;\n  border: none;\n}\n\n.hamburger-svg {\n  width: 65px;\n  height: 65px;\n}\n\n.line {\n  fill: none;\n  stroke: #ffd700;\n  stroke-linecap: round;\n  stroke-linejoin: round;\n  stroke-width: 3;\n}\n\n/* Header \u0026 logo sizing now controlled entirely by Header.tsx */\n\n/* Removed conflicting mobile padding - Header.tsx has correct symmetric padding */\n\n/* Dark mode scrollbar for entire page - Chrome/Edge/Safari */\nbody::-webkit-scrollbar {\n  width: 12px;\n}\n\nbody::-webkit-scrollbar-track {\n  background: #1a1a1a;\n}\n